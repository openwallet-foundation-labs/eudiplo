{
  "id": "pid",
  "description": "Personal ID",
  "config": {
    "scope": "pid",
    "format": "dc+sd-jwt",
    "display": [
      {
        "name": "PID",
        "description": "PID Credential",
        "locale": "en-US",
        "background_color": "#FFFFFF",
        "text_color": "#000000",
        "background_image": {
          "uri": "identity-card.jpg"
        },
        "logo": {
          "uri": "logo.jpg"
        }
      }
    ]
  },
  "vct": "urn:eudi:pid:de:1",
  "keyBinding": true,
  "statusManagement": true,
  "lifeTime": 604800,
  "configVersion": 2,
  "fields": [
    {
      "path": [
        "address",
        "country"
      ],
      "type": "string",
      "defaultValue": "DE",
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "address",
        "locality"
      ],
      "type": "string",
      "defaultValue": "KÖLN",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "City"
        },
        {
          "lang": "de-DE",
          "label": "Stadt"
        }
      ]
    },
    {
      "path": [
        "address",
        "postal_code"
      ],
      "type": "string",
      "defaultValue": "51147",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Postal Code"
        },
        {
          "lang": "de-DE",
          "label": "Postleitzahl"
        }
      ]
    },
    {
      "path": [
        "address",
        "street_address"
      ],
      "type": "string",
      "defaultValue": "HEIDESTRAẞE 17",
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "address"
      ],
      "type": "object",
      "defaultValue": {
        "street_address": "HEIDESTRAẞE 17",
        "locality": "KÖLN",
        "country": "DE",
        "postal_code": "51147"
      },
      "disclosable": true
    },
    {
      "path": [
        "age_birth_year"
      ],
      "type": "integer",
      "defaultValue": 1964,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "12"
      ],
      "type": "boolean",
      "defaultValue": true,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "14"
      ],
      "type": "boolean",
      "defaultValue": true,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "16"
      ],
      "type": "boolean",
      "defaultValue": true,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "18"
      ],
      "type": "boolean",
      "defaultValue": true,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "21"
      ],
      "type": "boolean",
      "defaultValue": true,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over",
        "65"
      ],
      "type": "boolean",
      "defaultValue": false,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "age_equal_or_over"
      ],
      "type": "object",
      "defaultValue": {
        "12": true,
        "14": true,
        "16": true,
        "18": true,
        "21": true,
        "65": false
      },
      "disclosable": true
    },
    {
      "path": [
        "age_in_years"
      ],
      "type": "integer",
      "defaultValue": 61,
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "birthdate"
      ],
      "type": "string",
      "defaultValue": "1964-08-12",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Date of Birth"
        },
        {
          "lang": "de-DE",
          "label": "Geburtsdatum"
        }
      ],
      "constraints": {
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    },
    {
      "path": [
        "family_name"
      ],
      "type": "string",
      "defaultValue": "MUSTERMANN",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Family Name"
        },
        {
          "lang": "de-DE",
          "label": "Nachname"
        }
      ]
    },
    {
      "path": [
        "given_name"
      ],
      "type": "string",
      "defaultValue": "ERIKA",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Given Name"
        },
        {
          "lang": "de-DE",
          "label": "Vorname"
        }
      ]
    },
    {
      "path": [
        "issuing_authority"
      ],
      "type": "string",
      "defaultValue": "DE",
      "mandatory": true,
      "disclosable": true
    },
    {
      "path": [
        "issuing_country"
      ],
      "type": "string",
      "defaultValue": "DE",
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Issuing Country"
        },
        {
          "lang": "de-DE",
          "label": "Ausstellungsland"
        }
      ]
    },
    {
      "path": [
        "nationalities",
        0
      ],
      "type": "string",
      "defaultValue": "DE",
      "disclosable": false
    },
    {
      "path": [
        "nationalities"
      ],
      "type": "array",
      "defaultValue": [
        "DE"
      ],
      "mandatory": true,
      "disclosable": true,
      "display": [
        {
          "lang": "en-US",
          "label": "Nationalities"
        },
        {
          "lang": "de-DE",
          "label": "Staatsangehörigkeiten"
        }
      ],
      "constraints": {
        "items": {
          "type": "string",
          "title": "Nationality"
        }
      }
    },
    {
      "path": [
        "place_of_birth",
        "locality"
      ],
      "type": "string",
      "defaultValue": "BERLIN",
      "mandatory": true,
      "disclosable": false
    },
    {
      "path": [
        "place_of_birth"
      ],
      "type": "object",
      "defaultValue": {
        "locality": "BERLIN"
      },
      "disclosable": true
    },
    {
      "path": [
        "source_document_type"
      ],
      "type": "string",
      "defaultValue": "id_card",
      "mandatory": true,
      "disclosable": true
    }
  ]
}
