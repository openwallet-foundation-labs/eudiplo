{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/KmsProviderInfoDto.schema.json",
  "title": "KmsProviderInfoDto",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique provider ID (matches the id in kms.json).",
      "example": "main-vault"
    },
    "type": {
      "type": "string",
      "description": "Type of the KMS provider (db, vault, aws-kms).",
      "example": "vault"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this provider instance.",
      "example": "Production HashiCorp Vault"
    },
    "capabilities": {
      "description": "Capabilities of this provider.",
      "allOf": [
        {
          "$ref": "./KmsProviderCapabilitiesDto.schema.json"
        }
      ]
    }
  },
  "required": [
    "name",
    "type",
    "capabilities"
  ],
  "additionalProperties": false
}