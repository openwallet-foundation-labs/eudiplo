{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation-labs/eudiplo/refs/heads/main/schemas/KeyChainCreateDto.schema.json",
  "title": "KeyChainCreateDto",
  "type": "object",
  "properties": {
    "usageType": {
      "enum": [
        "access",
        "attestation",
        "trustList",
        "statusList",
        "encrypt"
      ],
      "type": "string",
      "description": "Usage type determines the purpose of this key chain (access, attestation, etc.).",
      "example": "attestation"
    },
    "type": {
      "enum": [
        "standalone",
        "internalChain"
      ],
      "type": "string",
      "description": "Type of key chain to create.",
      "example": "internalChain"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description for the key chain.",
      "example": "Production credential signing key"
    },
    "kmsProvider": {
      "type": "string",
      "description": "KMS provider to use (defaults to the configured default provider).",
      "example": "vault"
    },
    "rotationPolicy": {
      "description": "Rotation policy configuration. Only applicable for the signing key (root CA never rotates).",
      "allOf": [
        {
          "$ref": "./RotationPolicyCreateDto.schema.json"
        }
      ]
    }
  },
  "required": [
    "usageType",
    "type"
  ],
  "additionalProperties": false
}