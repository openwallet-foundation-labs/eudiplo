{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/ExportEcJwk.schema.json",
  "title": "ExportEcJwk",
  "type": "object",
  "properties": {
    "kty": {
      "type": "string",
      "description": "Key type",
      "example": "EC"
    },
    "crv": {
      "type": "string",
      "description": "Curve",
      "example": "P-256"
    },
    "x": {
      "type": "string",
      "description": "X coordinate (base64url)"
    },
    "y": {
      "type": "string",
      "description": "Y coordinate (base64url)"
    },
    "d": {
      "type": "string",
      "description": "Private key (base64url)"
    },
    "alg": {
      "type": "string",
      "description": "Algorithm",
      "example": "ES256"
    },
    "kid": {
      "type": "string",
      "description": "Key ID"
    }
  },
  "required": [
    "kty",
    "crv",
    "x",
    "y",
    "d"
  ],
  "additionalProperties": false
}