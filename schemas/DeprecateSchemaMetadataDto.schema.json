{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation-labs/eudiplo/refs/heads/main/schemas/DeprecateSchemaMetadataDto.schema.json",
  "title": "DeprecateSchemaMetadataDto",
  "type": "object",
  "properties": {
    "deprecated": {
      "type": "boolean",
      "description": "Whether to mark this version as deprecated"
    },
    "message": {
      "type": "string",
      "description": "Deprecation message shown to consumers"
    },
    "supersededByVersion": {
      "type": "string",
      "description": "The version that supersedes this one"
    }
  },
  "required": [
    "deprecated"
  ],
  "additionalProperties": false
}