{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation-labs/eudiplo/refs/heads/main/schemas/KeyChainResponseDto.schema.json",
  "title": "KeyChainResponseDto",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the key chain."
    },
    "usageType": {
      "enum": [
        "access",
        "attestation",
        "trustList",
        "statusList",
        "encrypt"
      ],
      "type": "string",
      "description": "Usage type of the key chain."
    },
    "type": {
      "enum": [
        "standalone",
        "internalChain"
      ],
      "type": "string",
      "description": "Type of key chain (standalone or internalChain)."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description."
    },
    "kmsProvider": {
      "type": "string",
      "description": "KMS provider used for this key chain."
    },
    "rootCertificate": {
      "description": "Root CA certificate (only for internalChain type).",
      "allOf": [
        {
          "$ref": "./CertificateInfoDto.schema.json"
        }
      ]
    },
    "activePublicKey": {
      "description": "Active signing key's public key info.",
      "allOf": [
        {
          "$ref": "./PublicKeyInfoDto.schema.json"
        }
      ]
    },
    "activeCertificate": {
      "description": "Active signing key's certificate. Not present for encryption keys.",
      "allOf": [
        {
          "$ref": "./CertificateInfoDto.schema.json"
        }
      ]
    },
    "previousPublicKey": {
      "description": "Previous signing key's public key info (if in grace period).",
      "allOf": [
        {
          "$ref": "./PublicKeyInfoDto.schema.json"
        }
      ]
    },
    "previousCertificate": {
      "description": "Previous signing key's certificate (if in grace period).",
      "allOf": [
        {
          "$ref": "./CertificateInfoDto.schema.json"
        }
      ]
    },
    "previousKeyExpiry": {
      "format": "date-time",
      "type": "string",
      "description": "Previous key expiry date."
    },
    "rotationPolicy": {
      "description": "Rotation policy configuration.",
      "allOf": [
        {
          "$ref": "./RotationPolicyResponseDto.schema.json"
        }
      ]
    },
    "createdAt": {
      "format": "date-time",
      "type": "string",
      "description": "Timestamp when the key chain was created."
    },
    "updatedAt": {
      "format": "date-time",
      "type": "string",
      "description": "Timestamp when the key chain was last updated."
    }
  },
  "required": [
    "id",
    "usageType",
    "type",
    "kmsProvider",
    "activePublicKey",
    "rotationPolicy",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}