{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation-labs/eudiplo/refs/heads/main/schemas/TrustAuthorityEntry.schema.json",
  "title": "TrustAuthorityEntry",
  "type": "object",
  "properties": {
    "frameworkType": {
      "enum": [
        "aki",
        "etsi_tl",
        "openid_federation"
      ],
      "type": "string",
      "description": "Trust framework type"
    },
    "value": {
      "type": "string",
      "description": "URI of the trust list or trust anchor",
      "example": "https://example.com/trust-lists/members.jws"
    },
    "isLoTE": {
      "type": "boolean",
      "description": "Whether this trust authority is a List of Trusted Entities (LoTE)"
    }
  },
  "additionalProperties": false
}