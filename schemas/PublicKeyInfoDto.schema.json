{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/PublicKeyInfoDto.schema.json",
  "title": "PublicKeyInfoDto",
  "type": "object",
  "properties": {
    "kty": {
      "type": "string",
      "description": "Key type (e.g., EC).",
      "example": "EC"
    },
    "alg": {
      "type": "string",
      "description": "Key algorithm (e.g., ES256).",
      "example": "ES256"
    },
    "kid": {
      "type": "string",
      "description": "Key ID."
    },
    "crv": {
      "type": "string",
      "description": "Curve (for EC keys).",
      "example": "P-256"
    }
  },
  "required": [
    "kty"
  ],
  "additionalProperties": false
}